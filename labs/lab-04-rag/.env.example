# --- watsonx.ai ---
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_APIKEY=__YOUR_IBM_CLOUD_API_KEY__
WATSONX_PROJECT_ID=__YOUR_WX_PROJECT_ID__
LLM_MODEL_ID=ibm/granite-3-2-8b-instruct
LLM_TEMPERATURE=0.2
LLM_MAX_NEW_TOKENS=300

# --- Retrieval backend: 'chroma' (default) or 'elastic' ---
RAG_BACKEND=chroma

# --- Local Chroma backend ---
CHROMA_DIR=.chroma
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Elasticsearch / watsonx Discovery backend (optional) ---
ES_HOST=https://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=
ES_INDEX=watsonx_kb
# Or, for IBM Cloud Databases for Elasticsearch:
# ES_CLOUD_ID=__paste_cloud_id__
# ES_API_KEY=__paste_api_key__
